                      {
                          "parameters":  {
                                             "jsCode":  "     const store = $getWorkflowStaticData(\u0027global\u0027);\n\n     const input = $(\u0027prepare memory\u0027).first().json;\n     const deepseekOutput = $input.first().json;\n\n     const aiReply = deepseekOutput.choices?.[0]?.message?.content;\n     const limit = input.memoryLimit || 10;\n\n     if (!aiReply) {\n       throw new Error(\u0027DeepSeek did not return choices[0].message.content\u0027);\n     }\n\n     let history = input.existingMemory || [];\n\n     if (input.command !== \u0027memory\u0027) {\n       history.push({ role: \u0027user\u0027, content: input.text });\n       history.push({ role: \u0027assistant\u0027, content: aiReply });\n       history = history.slice(-limit);\n       store[input.memoryKey] = history;\n     }\n\n     return [{\n       json: {\n         to: input.groupId,\n         message: aiReply\n       }\n     }];"
                                         },
